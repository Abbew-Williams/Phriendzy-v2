{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID from Firebase Auth." },
        "firstName": { "type": "string", "description": "User's first name." },
        "lastName": { "type": "string", "description": "User's last name." },
        "username": { "type": "string", "description": "User's public username." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "URL for the user's avatar image." },
        "bio": { "type": "string", "description": "A short bio for the user." },
        "followersCount": { "type": "number", "description": "Number of followers." },
        "followingCount": { "type": "number", "description": "Number of users this user is following." },
        "usernameLastChanged": { "type": "string", "format": "date-time", "description": "The last time the username was changed." },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user", "description": "User role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of user creation." }
      },
      "required": ["uid", "username", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "A post created by a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "caption": { "type": "string" },
        "mediaUrl": { "type": "string", "format": "uri" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "privacy": { "type": "string", "enum": ["public", "friends", "private"], "description": "Post privacy setting." },
        "allowComments": { "type": "boolean", "description": "Whether users can comment on the post." },
        "allowDuet": { "type": "boolean", "description": "Whether users can create a duet with the post." },
        "allowStitch": { "type": "boolean", "description": "Whether users can create a stitch with the post." }
      },
      "required": ["authorId", "mediaUrl", "mediaType", "createdAt", "privacy"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number", "description": "Number of likes on the comment." },
        "parentId": { "type": "string", "description": "ID of the parent comment if this is a reply." }
      },
      "required": ["authorId", "postId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Represents a notification for a user.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "comment", "follow", "live_award"] },
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "postId": { "type": "string", "description": "ID of the post related to the notification (for likes/comments)." },
        "commentId": { "type": "string", "description": "ID of the comment related to the notification." },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "fromUserId", "toUserId", "read", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a conversation between two or more users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Status": {
      "title": "Status",
      "description": "A temporary status update (story) from a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "mediaUrl": { "type": "string", "format": "uri" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "mediaUrl", "mediaType", "createdAt", "expiresAt"]
    },
     "LiveStream": {
      "title": "Live Stream",
      "description": "Represents a live video stream.",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "viewerCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostId", "title", "status", "createdAt"]
    },
    "LiveStreamComment": {
      "title": "Live Stream Comment",
      "description": "A comment on a live stream.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "authorAvatarUrl": { "type": "string", "format": "uri" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorUsername", "text", "createdAt"]
    },
    "AppSettings": {
      "title": "Application Settings",
      "description": "Stores global application settings configurable by an admin.",
      "type": "object",
      "properties": {
        "goLiveFollowerMinimum": {
          "type": "number",
          "description": "The minimum number of followers a user needs to go live."
        },
        "aiContentScanningEnabled": {
          "type": "boolean",
          "description": "Enable AI to automatically scan content for violations."
        },
        "aiViolationSensitivity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "The sensitivity level for AI violation detection."
        },
        "mediaApiBaseUrl": {
          "type": "string",
          "description": "The base URL for the custom media upload API."
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "apple.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores public user profile data."
    },
    "/users/{userId}/following/{followingId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Subcollection to track users that this user is following. The document ID is the ID of the user being followed."
    },
    "/users/{userId}/followers/{followerId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Subcollection to track users that are following this user. The document ID is the ID of the follower."
    },
    "/users/{userId}/likes/{postId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Subcollection of posts liked by the user. The document ID is the post ID."
    },
    "/users/{userId}/saved/{postId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Subcollection of posts saved by the user. The document ID is the post ID."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores all posts."
    },
    "/posts/{postId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Subcollection of users who liked the post. The document ID is the user ID."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Subcollection for comments on a post."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Notifications for a specific user."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores all chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Subcollection for messages within a chat."
    },
    "/users/{userId}/statuses/{statusId}": {
      "schema": { "$ref": "#/entities/Status" },
      "description": "Subcollection for a user's statuses (stories)."
    },
    "/liveStreams/{liveId}": {
      "schema": { "$ref": "#/entities/LiveStream" },
      "description": "Stores all active and past live streams."
    },
    "/liveStreams/{liveId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/LiveStreamComment" },
      "description": "Subcollection for comments on a live stream."
    },
    "/config/{settingId}": {
      "schema": { "$ref": "#/entities/AppSettings" },
      "description": "Stores global application settings. Use a consistent document ID like 'appSettings'."
    }
  }
}
